# 复制成 .env（gitignore 已排除），填入你的 API keys

# === 科研 / ML 相关 ===
MP_API_KEY=your_materials_project_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
WANDB_API_KEY=your_wandb_key
HF_TOKEN=your_huggingface_token

# === Safari AI 插件相关（配置时手动复制到插件设置面板） ===
# 沉浸式翻译 - DeepL 引擎: https://www.deepl.com/pro-api (免费版 50万字符/月)
DEEPL_API_KEY=your_deepl_api_key
# 沉浸式翻译 - 谷歌翻译: 免费无限，无需 key
# 沉浸式翻译 - Claude 引擎: 复用上面的 ANTHROPIC_API_KEY
# 沉浸式翻译 - OpenAI 引擎: 复用上面的 OPENAI_API_KEY
