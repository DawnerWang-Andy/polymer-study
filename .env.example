# 复制成 .env（gitignore 已排除），填入你的 API keys

# === 科研 / ML 相关 ===
MP_API_KEY=your_materials_project_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
WANDB_API_KEY=your_wandb_key
HF_TOKEN=your_huggingface_token

# === Safari AI 插件相关（国内直连版） ===
# 大部分国产插件（Kimi/豆包/有道/秘塔/Web Clipper）用手机号登录即可，无需 API Key。
# 下面这些 Key 仅在你想用国产 AI 做自动化脚本时才需要：

# Kimi API (Moonshot) - https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=your_kimi_key

# 智谱 GLM (完全免费) - https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=your_zhipu_key

# DeepSeek (¥1/百万 token) - https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_key

# 豆包 (火山方舟) - https://console.volcengine.com/ark
DOUBAO_API_KEY=your_doubao_key
