# polymer-study 环境变量模板
# 复制为 .env 后填入真实值；.env 不进 git

# ------------------------------ Zotero ---------------------------------
# 从 https://www.zotero.org/settings/keys 生成，勾选：
#   [x] Allow library access
#   [x] Allow write access
ZOTERO_API_KEY=

# 同一页面的 "Your userID for use in API calls"，纯数字
ZOTERO_LIBRARY_ID=

# user = 个人库；group = 群组库（此时 LIBRARY_ID 填群组 ID）
ZOTERO_LIBRARY_TYPE=user

# Zotero 桌面 Local API，仅在打开 Zotero 且启用 "Allow other applications
# on this computer to communicate with Zotero" 时可用；默认端口 23119。
# 留空则跳过本地探测，全部走 Web API。
ZOTERO_LOCAL_API=http://127.0.0.1:23119

# ------------------------------ 其它 -----------------------------------
# MP_API_KEY 等其它凭证可继续在下面加
